# ===================================================================
# DragonHead 环境变量配置模板
# 复制此文件为 .env 并填入真实值
#   cp .env.example .env
# ===================================================================

# -------------------------------------------
# Spring Profile
# -------------------------------------------
# prod: 使用 MySQL（生产推荐）
# dev:  使用 H2 内存数据库（开发）
SPRING_PROFILES_ACTIVE=prod

# -------------------------------------------
# MySQL 数据库
# -------------------------------------------
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=adeptify
MYSQL_USER=dragon
MYSQL_PASSWORD=dragon123
MYSQL_PORT=3306

# -------------------------------------------
# Dragon Store 类型 (MYSQL / MEMORY)
# -------------------------------------------
DRAGON_STORE_TYPE=MYSQL

# -------------------------------------------
# 应用端口
# -------------------------------------------
APP_PORT=8080

# -------------------------------------------
# 飞书渠道配置
# -------------------------------------------
# 飞书机器人 App ID
FEISHU_APP_ID=
# 飞书机器人 App Secret
FEISHU_APP_SECRET=
# 机器人 Open ID（在飞书后台获取）
FEISHU_ROBOT_OPENID=
# 群聊唤醒词（为空则不需要唤醒词/@机器人）
FEISHU_WAKEWORD=
# 私信白名单 openId 列表，逗号分隔
FEISHU_WHITELIST=

# -------------------------------------------
# LLM 配置（至少配置一个）
# -------------------------------------------
# MiniMax
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# Kimi (Moonshot)
KIMI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# -------------------------------------------
# 默认 Character ID（单 Character Fallback 路径）
# -------------------------------------------
DEFAULT_CHARACTER_ID=
